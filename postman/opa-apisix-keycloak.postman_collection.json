{
  "info": {
    "_postman_id": "poc-opa-apisix-keycloak",
    "name": "OPA + APISIX + Keycloak PoC",
    "description": "Colección para la PoC de autorización con OPA + Apache APISIX + Keycloak + OpenBao.\n\nUso:\n1. Ejecutar las peticiones de '00 - Auth' para obtener los tokens (se guardan automáticamente como variables de colección).\n2. El resto de carpetas usan {{token_alice}}, {{token_bob}}, {{token_carol}} en sus headers de autorización.\n\nTodas las URLs y credenciales están definidas como variables de colección — no es necesario importar un environment aparte.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Auth (Impersonación)",
      "item": [
        {
          "name": "Get Token - alice (user, tenant acme)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('token_alice', pm.response.json().access_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",     "value": "password",              "type": "text" },
                { "key": "client_id",      "value": "{{client_id}}",         "type": "text" },
                { "key": "client_secret",  "value": "{{client_secret}}",     "type": "text" },
                { "key": "username",       "value": "{{alice_username}}",    "type": "text" },
                { "key": "password",       "value": "{{alice_password}}",    "type": "text" },
                { "key": "scope",          "value": "openid profile email",  "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{keycloak_realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{keycloak_realm}}", "protocol", "openid-connect", "token"]
            }
          },
          "response": []
        },
        {
          "name": "Get Token - bob (admin, tenant acme)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('token_bob', pm.response.json().access_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",     "value": "password",              "type": "text" },
                { "key": "client_id",      "value": "{{client_id}}",         "type": "text" },
                { "key": "client_secret",  "value": "{{client_secret}}",     "type": "text" },
                { "key": "username",       "value": "{{bob_username}}",      "type": "text" },
                { "key": "password",       "value": "{{bob_password}}",      "type": "text" },
                { "key": "scope",          "value": "openid profile email",  "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{keycloak_realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{keycloak_realm}}", "protocol", "openid-connect", "token"]
            }
          },
          "response": []
        },
        {
          "name": "Get Token - carol (user, tenant globex)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('token_carol', pm.response.json().access_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",     "value": "password",              "type": "text" },
                { "key": "client_id",      "value": "{{client_id}}",         "type": "text" },
                { "key": "client_secret",  "value": "{{client_secret}}",     "type": "text" },
                { "key": "username",       "value": "{{carol_username}}",    "type": "text" },
                { "key": "password",       "value": "{{carol_password}}",    "type": "text" },
                { "key": "scope",          "value": "openid profile email",  "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{keycloak_realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{keycloak_realm}}", "protocol", "openid-connect", "token"]
            }
          },
          "response": []
        },
        {
          "name": "Introspect Token - alice",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{client_id}}",     "type": "string" },
                { "key": "password", "value": "{{client_secret}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token", "value": "{{token_alice}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{keycloak_realm}}/protocol/openid-connect/token/introspect",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{keycloak_realm}}", "protocol", "openid-connect", "token", "introspect"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 - Fase 1 - Gateway",
      "item": [
        {
          "name": "GET Conversations - alice (200)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_alice}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apisix_url}}/api/conversations",
              "host": ["{{apisix_url}}"],
              "path": ["api", "conversations"]
            }
          },
          "response": []
        },
        {
          "name": "DELETE Conversations - alice (403)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_alice}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{apisix_url}}/api/conversations",
              "host": ["{{apisix_url}}"],
              "path": ["api", "conversations"]
            }
          },
          "response": []
        },
        {
          "name": "DELETE Conversations - bob (200)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_bob}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{apisix_url}}/api/conversations",
              "host": ["{{apisix_url}}"],
              "path": ["api", "conversations"]
            }
          },
          "response": []
        },
        {
          "name": "GET Conversations - carol (403 cross-tenant)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token_carol}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apisix_url}}/api/conversations",
              "host": ["{{apisix_url}}"],
              "path": ["api", "conversations"]
            }
          },
          "response": []
        },
        {
          "name": "OPA Debug - gateway policy (DELETE alice)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": {\n    \"type\": \"http\",\n    \"request\": {\n      \"method\": \"DELETE\",\n      \"path\": \"/api/conversations\",\n      \"headers\": { \"authorization\": \"Bearer {{token_alice}}\" }\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{opa_url}}/v1/data/gateway",
              "host": ["{{opa_url}}"],
              "path": ["v1", "data", "gateway"]
            }
          },
          "response": []
        }
      ]
    },
